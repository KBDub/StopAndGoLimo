run = "php -S 0.0.0.0:8000 -t ."

entrypoint = "index.php"
modules = ["nodejs-20", "postgresql-16", "php-8.4"]

[nix]
channel = "stable-22_11"

[deployment]
run = ["bash", "scripts/startup.sh"]
deploymentTarget = "vm"
build = ["bash", "-c", "composer install --no-scripts --no-dev --optimize-autoloader && rm -f bootstrap/cache/services.php bootstrap/cache/packages.php && php artisan package:discover --ansi && npm ci && npx vite build && php artisan config:cache && php artisan route:cache && php artisan view:cache && php artisan event:cache"]

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3001

[[ports]]
localPort = 5002
externalPort = 3002

[[ports]]
localPort = 5003
externalPort = 3003

[[ports]]
localPort = 8000
externalPort = 8000

[agent]
expertMode = true

[userenv]

[userenv.shared]
APP_NAME = "Top 5 Percent"
APP_URL = "https://4634af69-a684-4f94-be55-4fcaddde2ae2-00-3f36pojhfc1hn.riker.replit.dev"
DB_CONNECTION = "pgsql"
DB_HOST = "helium"
DB_PORT = "5432"
DB_DATABASE = "heliumdb"
DB_USERNAME = "postgres"
ASSET_URL = "https://4634af69-a684-4f94-be55-4fcaddde2ae2-00-3f36pojhfc1hn.riker.replit.dev"
SCOUT_DRIVER = "meilisearch"
MEILISEARCH_HOST = "http://localhost:8000"
MEILISEARCH_KEY = "OK51DYdyix57qXmQLGkDaq2L4ieZzFB3"
DB_PASSWORD = "password"
STRIPE_KEY = "pk_test_placeholder_top5pct"
STRIPE_SECRET = "sk_test_placeholder_top5pct"
PAYMENTS_TYPE = "offline"

[userenv.development]
SESSION_DRIVER = "file"
CACHE_STORE = "file"
QUEUE_CONNECTION = "sync"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Laravel Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Meilisearch"

[[workflows.workflow]]
name = "Laravel Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/startup-dev.sh"
waitForPort = 5000

[[workflows.workflow]]
name = "Meilisearch"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "meilisearch --http-addr 0.0.0.0:8000 --master-key OK51DYdyix57qXmQLGkDaq2L4ieZzFB3 --db-path ./storage/meilisearch --env production --log-level INFO"
