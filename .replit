run = "php -S 0.0.0.0:8000 -t ."

entrypoint = "index.php"
modules = ["nodejs-20", "php-8.4", "postgresql-16", "python-3.11"]

[nix]
channel = "stable-22_11"

[deployment]
run = ["bash", "scripts/startup.sh"]
deploymentTarget = "autoscale"
build = ["bash", "-c", "composer install --no-scripts --no-dev --optimize-autoloader && rm -f bootstrap/cache/services.php bootstrap/cache/packages.php && php artisan package:discover --ansi && npm ci && npx vite build && php artisan config:cache && php artisan route:cache && php artisan view:cache && php artisan event:cache"]

[[ports]]
localPort = 3000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5003

[[ports]]
localPort = 5173
externalPort = 5173

[[ports]]
localPort = 8000
externalPort = 8000

[agent]
expertMode = true

[userenv]

[userenv.shared]
APP_NAME = "Top 5 Percent"
DB_CONNECTION = "pgsql"
DB_HOST = "helium"
DB_PORT = "5432"
DB_DATABASE = "heliumdb"
DB_USERNAME = "postgres"
DB_PASSWORD = "password"
STRIPE_KEY = "pk_live_placeholder"
STRIPE_SECRET = "sk_live_placeholder"
PAYMENTS_TYPE = "stripe"
STAFF_ADMIN_HASH = "$2y$12$TJGTDRPVswe8zdRzH1QYpu3OFlxUc1U4yMtO2D8oKzslEeHJQoGgC"
ASSET_URL = "https://top-5-pct.replit.app"
STRIPE_WEBHOOK_SECRET = "whsec_placeholder"
SCOUT_DRIVER = "database"
MAIL_MAILER = "smtp"
MAIL_SCHEME = "ssl"
MAIL_FROM_NAME = "Stop and Go Airport Shuttle"
MAIL_HOST = "smtp.secureserver.net"
MAIL_PORT = "465"
MAIL_USERNAME = "vincent@newlenoxlimoservice.com"
MAIL_FROM_ADDRESS = "vincent@newlenoxlimoservice.com"

[userenv.development]
SESSION_DRIVER = "file"
CACHE_STORE = "file"
QUEUE_CONNECTION = "sync"

[userenv.production]
APP_URL = "https://top-5-pct.replit.app"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Laravel Server"

[[workflows.workflow]]
name = "Laravel Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/startup-dev.sh"
waitForPort = 5000

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000
